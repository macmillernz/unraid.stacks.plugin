<div id="stacksUI-settings-page-root" data-csrf-token="<?= htmlspecialchars($var['csrf_token'] ?? '') ?>">
  <h1>Stacks UI</h1>
  <p class="stacksUI-hint">
    Controls which native Unraid tabs are visible. Changes take effect immediately, but a full
    page reload (not just clicking between tabs) is needed to see a tab appear or disappear from
    the top nav bar.
  </p>

  <div class="stacksUI-settings-toggle-row">
    <label for="stacksUI-toggle-hideDocker">Hide Docker tab</label>
    <input type="checkbox" id="stacksUI-toggle-hideDocker">
  </div>
  <p class="stacksUI-hint">Hides the built-in "Docker" tab, since stacks are managed from the Stacks tab instead.</p>

  <div class="stacksUI-settings-toggle-row">
    <label for="stacksUI-toggle-hideApps">Hide Apps tab</label>
    <input type="checkbox" id="stacksUI-toggle-hideApps">
  </div>
  <p class="stacksUI-hint">Hides Community Applications' "Apps" tab, since the Stacks App Store covers app installs instead.</p>

  <div class="stacksUI-settings-toggle-row">
    <label for="stacksUI-toggle-enableAppStore">Enable Stacks App Store tab</label>
    <input type="checkbox" id="stacksUI-toggle-enableAppStore">
  </div>
  <p class="stacksUI-hint">Shows or hides stacksUI's own "Stacks App Store" tab.</p>

  <p id="stacksUI-settings-page-error" class="stacksUI-error" style="display:none"></p>
  <button id="stacksUI-settings-page-save" class="stacksUI-btn">Save</button>
  <span id="stacksUI-settings-page-saved" class="stacksUI-hint" style="display:none">Saved.</span>
</div>

<script src="/plugins/stacksUI/js/stacksUISettings.js"></script>
